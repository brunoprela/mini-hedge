# Database
DATABASE_URL=postgresql+asyncpg://minihedge:minihedge@localhost:5433/minihedge
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5

# Application
APP_ENV=local
LOG_LEVEL=DEBUG

# JWT (MUST change in production)
JWT_SECRET=minihedge-dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# OpenFGA
FGA_API_URL=http://localhost:8080
FGA_STORE_NAME=minihedge
FGA_ENABLED=true

# Keycloak
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_BROWSER_URL=http://localhost:8180
KEYCLOAK_REALM=minihedge
KEYCLOAK_CLIENT_ID=mini-hedge-ui
KEYCLOAK_OPS_REALM=minihedge-ops
KEYCLOAK_OPS_CLIENT_ID=mini-hedge-ops-ui

# Adapter configuration — external data sources
# Set all three to "mock-exchange" to use the external mock-exchange service.
# "in-process"/"seed" options are backward-compat for broker/reference-data only.
MOCK_EXCHANGE_URL=http://localhost:8100
MOCK_EXCHANGE_KAFKA_BOOTSTRAP_SERVERS=localhost:9192
MARKET_DATA_SOURCE=mock-exchange          # "mock-exchange"
BROKER_ADAPTER=mock-exchange              # "mock-exchange" | "in-process" | "fix"
REFERENCE_DATA_SOURCE=mock-exchange       # "mock-exchange" | "seed"

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081

# Redis (SSE streaming)
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3100"]
