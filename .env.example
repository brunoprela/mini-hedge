# Database
DATABASE_URL=postgresql+asyncpg://minihedge:minihedge@localhost:5433/minihedge

# Application
APP_ENV=local
LOG_LEVEL=DEBUG

# Market Data Simulator
SIMULATOR_INTERVAL_MS=1000
SIMULATOR_ENABLED=true

# Kafka (required — docker compose provides the broker)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081

# Redis (SSE streaming)
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true
