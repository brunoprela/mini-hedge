{
  "realm": "minihedge-ops",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "otpPolicyType": "totp",
  "otpPolicyAlgorithm": "HmacSHA1",
  "otpPolicyDigits": 6,
  "otpPolicyPeriod": 30,
  "otpPolicyInitialCounter": 0,
  "otpPolicyLookAheadWindow": 1,
  "requiredActions": [
    {
      "alias": "CONFIGURE_TOTP",
      "name": "Configure OTP",
      "providerId": "CONFIGURE_TOTP",
      "enabled": true,
      "defaultAction": true,
      "priority": 10
    }
  ],
  "roles": {
    "realm": [
      { "name": "ops_admin", "description": "Full platform administration" },
      { "name": "ops_viewer", "description": "Read-only platform access" }
    ]
  },
  "authenticationFlows": [
    {
      "alias": "browser",
      "description": "Browser-based authentication with mandatory OTP for all ops users",
      "providerId": "basic-flow",
      "topLevel": true,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "auth-cookie",
          "authenticatorFlow": false,
          "requirement": "ALTERNATIVE",
          "priority": 10
        },
        {
          "authenticator": "auth-spnego",
          "authenticatorFlow": false,
          "requirement": "DISABLED",
          "priority": 20
        },
        {
          "authenticatorFlow": true,
          "requirement": "ALTERNATIVE",
          "priority": 30,
          "flowAlias": "ops-browser-forms"
        }
      ]
    },
    {
      "alias": "ops-browser-forms",
      "description": "Username/password followed by mandatory OTP",
      "providerId": "basic-flow",
      "topLevel": false,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "auth-username-password-form",
          "authenticatorFlow": false,
          "requirement": "REQUIRED",
          "priority": 10
        },
        {
          "authenticator": "auth-otp-form",
          "authenticatorFlow": false,
          "requirement": "REQUIRED",
          "priority": 20
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "mini-hedge-ops-ui",
      "name": "Mini Hedge Ops UI",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:3100/*"
      ],
      "webOrigins": [
        "http://localhost:3100"
      ],
      "defaultClientScopes": ["openid", "profile", "email"],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:3100/*"
      },
      "protocolMappers": [
        {
          "name": "audience-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "mini-hedge-ops-ui",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "sub-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-sub-mapper",
          "consentRequired": false,
          "config": {
            "id.token.claim": "true",
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "ops-admin@minihedge.dev",
      "email": "ops-admin@minihedge.dev",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Ops",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": ["ops_admin"],
      "requiredActions": ["CONFIGURE_TOTP"]
    },
    {
      "username": "ops-viewer@minihedge.dev",
      "email": "ops-viewer@minihedge.dev",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Ops",
      "lastName": "Viewer",
      "credentials": [
        {
          "type": "password",
          "value": "viewer",
          "temporary": false
        }
      ],
      "realmRoles": ["ops_viewer"],
      "requiredActions": ["CONFIGURE_TOTP"]
    }
  ]
}
