{
  "name": "mini-hedge-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Root workspace for the mini-hedge monorepo (UIs + shared packages + e2e tests).",
  "scripts": {
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:setup": "playwright test tests-e2e/auth.setup.ts",
    "test:e2e:install": "playwright install --with-deps chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^20"
  },
  "packageManager": "pnpm@9.15.4"
}
