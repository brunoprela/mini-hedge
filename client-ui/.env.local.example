# Required — authentication
AUTH_SECRET=client-ui-secret-change-me
KEYCLOAK_CLIENT_ID=investor-portal
KEYCLOAK_CLIENT_SECRET=investor-portal-secret
KEYCLOAK_ISSUER=http://localhost:8180/realms/investors

# Required — API and app URL
API_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3200
AUTH_URL=http://localhost:3200
AUTH_TRUST_HOST=true

